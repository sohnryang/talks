digraph bad_fusion {
    rankdir = "LR";

    W1 [shape=square,label=<W<FONT POINT-SIZE="10"><SUB>1</SUB></FONT>>];
    W2 [shape=square,label=<W<FONT POINT-SIZE="10"><SUB>2</SUB></FONT>>];
    X [shape=square];
    out [shape=square];

    subgraph cluster_fused {
        label = "subgraph 1";
        style = "dashed,rounded";
        color = gray50;
        matmul1 [label="matmul"];
    }
    
    subgraph cluster_fused2 {
        label = "subgraph 1";
        style = "dashed,rounded";
        color = gray50;
        relu2 [label="relu"];
    }

    relu1 [label="relu"];
    matmul2 [label="matmul"];

    W1 -> matmul1;
    X -> matmul1;
    matmul1 -> relu1;

    W2 -> matmul2;
    relu1 -> matmul2;
    matmul2 -> relu2;
    relu2 -> out;
}
