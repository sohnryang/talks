digraph arbitrary_cost {
    rankdir = "LR";
    
    W1 [shape=square,label=<W<FONT POINT-SIZE="10"><SUB>1</SUB></FONT>>];
    W2 [shape=square,label=<W<FONT POINT-SIZE="10"><SUB>2</SUB></FONT>>];
    X [shape=square];
    out [shape=square];
    matmul1 [label="matmul\ncost = 10"];
    matmul2 [label="matmul\ncost = 2"];
    pointwise1 [label="pointwise\ncost = 5"];
    pointwise2 [label="pointwise\ncost = 20"];
    W1 -> matmul1;
    X -> matmul1;
    matmul1 -> pointwise1;
    
    W2 -> matmul2;
    pointwise1 -> matmul2;
    matmul2 -> pointwise2;
    pointwise2 -> out;
}
